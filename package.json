    "preview": "vite preview"
  },
  "devDependencies": {
    "toml": "^4.1.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-wasm": "^3.3.0",
    "vite-plugin-top-level-await": "^1.4.0"
  }
}
